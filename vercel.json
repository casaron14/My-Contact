{
  "version": 2,
  "routes": [
    { "src": "/book",               "dest": "/form/book.html" },
    { "src": "/seminar",            "dest": "/form/seminar.html" },
    { "src": "/api/get-slots",      "dest": "/api/get-slots.js" },
    { "src": "/api/book-slot",      "dest": "/api/book-slot.js" },
    { "src": "/api/submit",         "dest": "/api/submit.js" },
    { "src": "/api/seminar",        "dest": "/api/seminar.js" },
    { "src": "/api/admin/auth",     "dest": "/api/admin/auth.js" },
    { "src": "/api/admin/stats",    "dest": "/api/admin/stats.js" },
    { "src": "/api/admin/bookings", "dest": "/api/admin/bookings.js" },
    { "src": "/(.*)",               "dest": "/public/$1" }
  ]
}
