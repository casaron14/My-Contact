# ============================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================
# Copy this file to .env.local and populate with real values
# NEVER commit .env.local to Git
# ============================================

# ========== NODE ENVIRONMENT ==========
NODE_ENV=production
ENVIRONMENT=production

# ========== VERCEL DEPLOYMENT ==========
VERCEL_URL=
VERCEL_ENV=production

# ========== GOOGLE SERVICES ==========
# Google Service Account (for Sheets, Calendar, Gmail)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Bookings

# ========== GOOGLE CLOUD ==========
GOOGLE_PROJECT_ID=

# ========== TELEGRAM NOTIFICATIONS ==========
TG_BOT_TOKEN=
TG_CHAT_ID=

# ========== APPLICATION SETTINGS ==========
# Email settings
REMINDER_EMAIL=

# API Settings
API_RATE_LIMIT_MAX=5
API_RATE_LIMIT_WINDOW_MS=3600000

# Booking settings
BOOKING_TIMEZONE=Africa/Johannesburg
BOOKING_SLOT_START_HOUR=16
BOOKING_SLOT_END_HOUR=21
BOOKING_SLOT_DURATION_MIN=30
BOOKING_DAYS_AVAILABLE=3

# ========== SECURITY SETTINGS ==========
# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=https://charityaron.vercel.app,https://www.charityaron.com

# Disable debug logs in production
DEBUG=false
LOG_LEVEL=error

# ========== RECAPTCHA (if implementing) ==========
# RECAPTCHA_SECRET_KEY=
# NEXT_PUBLIC_RECAPTCHA_PUBLIC_KEY=

# ========== DEPLOYMENT-SPECIFIC ==========
# GitHub
GITHUB_TOKEN=

# Slack notifications (optional)
# SLACK_WEBHOOK_URL=

# ========== EMAIL SERVICE (Optional - for transactional emails) ==========
# SendGrid or similar
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=

# AWS (if using S3 for uploads)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
